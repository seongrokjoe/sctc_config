<UserControl x:Class="SCTC_CONFIG.Views.XmlMainPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <UserControl.Resources>
        <DataTemplate x:Key="XmlToggleItemTemplate">
            <Border Style="{StaticResource ItemRow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="{Binding Key}"
                               Style="{StaticResource KeyLabel}"/>
                    <ToggleButton Grid.Column="1"
                                  Style="{StaticResource ValueToggleLower}"
                                  IsChecked="{Binding IsEnabled}"/>
                </Grid>
            </Border>
        </DataTemplate>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0">
            <Border DockPanel.Dock="Top" Style="{StaticResource XmlPanelHeader}">
                <TextBlock Text="Main" Style="{StaticResource XmlPanelHeaderText}"/>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                <ItemsControl ItemsSource="{Binding Items}"
                              ItemTemplate="{StaticResource XmlToggleItemTemplate}"
                              Margin="0"/>
            </ScrollViewer>
        </DockPanel>

        <DockPanel Grid.Row="1">
            <Border DockPanel.Dock="Top" Style="{StaticResource XmlPanelHeader}">
                <TextBlock Text="SCD" Style="{StaticResource XmlPanelHeaderText}"/>
            </Border>
            <ScrollViewer VerticalScrollBarVisibility="Auto" Background="White">
                <ItemsControl ItemsSource="{Binding ScdItems}"
                              ItemTemplate="{StaticResource XmlToggleItemTemplate}"
                              Margin="0"/>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</UserControl>
